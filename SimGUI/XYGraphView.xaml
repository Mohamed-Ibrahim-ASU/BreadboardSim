<Window x:Class="SimGUI.XYGraphView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Transfer Characteristic (XY)"
        Height="400" Width="760"
        MinHeight="240" MinWidth="420"
        Loaded="Window_Loaded"
        SizeChanged="Window_SizeChanged"
        Closing="Window_Closing">

    <Window.Resources>
        <!-- Exact copies of the styles from GraphView.xaml -->
        <Style TargetType="Button">
            <Setter Property="Background"      Value="#F8F9FA"/>
            <Setter Property="Foreground"      Value="#212529"/>
            <Setter Property="BorderBrush"     Value="#CED4DA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="10,4"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background"  Value="#E2E6EA"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#DAE0E5"/>
                            </Trigger>
                            <Trigger Property="IsPressed"   Value="True">
                                <Setter TargetName="border" Property="Background"  Value="#DAE0E5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ToggleButton">
            <Setter Property="Background"      Value="#F8F9FA"/>
            <Setter Property="Foreground"      Value="#212529"/>
            <Setter Property="BorderBrush"     Value="#CED4DA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="10,4"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E2E6EA"/>
                            </Trigger>
                            <Trigger Property="IsChecked"   Value="True">
                                <Setter TargetName="border" Property="Background"  Value="#0D6EFD"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#0A58CA"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ToolTip">
            <Setter Property="Background"      Value="#2B2B2B"/>
            <Setter Property="Foreground"      Value="#F1F1F1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="#444"/>
            <Setter Property="Padding"         Value="8,6"/>
            <Setter Property="HasDropShadow"   Value="True"/>
        </Style>
    </Window.Resources>

    <!-- ══ same 3-row × 3-col skeleton as GraphView.xaml ══════════════════ -->
    <Grid x:Name="MainGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>   <!-- plot row         -->
            <RowDefinition Height="30"/>   <!-- H-labels / X-axis-->
            <RowDefinition Height="36"/>   <!-- toolbar          -->
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="65"/> <ColumnDefinition Width="1*"/> <ColumnDefinition Width="65"/> </Grid.ColumnDefinitions>

        <!-- ── Plot background (LightYellow — matches GraphArea) ─────────── -->
        <Canvas x:Name="PlotArea"   Grid.Column="1" Grid.Row="0"
                ClipToBounds="True" Background="LightYellow"/>

        <!-- ── Grid lines (single Path, drawn in code — matches GraphDividers) -->
        <Path   x:Name="GraphDividers" Grid.Column="1" Grid.Row="0"
                Stroke="#B0B0B0" StrokeThickness="0.8" IsHitTestVisible="False"/>
                
        <Path   x:Name="GraphOriginAxes" Grid.Column="1" Grid.Row="0"
                Stroke="#444" StrokeThickness="1.5" IsHitTestVisible="False"/>

        <!-- ── Trace canvas (Polylines added in constructor) ─────────────── -->
        <Canvas x:Name="TraceCanvas" Grid.Column="1" Grid.Row="0"
                IsHitTestVisible="False" ClipToBounds="True"/>

        <!-- ── Hover overlay (crosshair + tooltip) ───────────────────────── -->
        <Canvas x:Name="HoverOverlay" Grid.Column="1" Grid.Row="0"
                Background="Transparent" ClipToBounds="True" Panel.ZIndex="20"
                MouseDown="HoverOverlay_MouseDown"
                MouseUp="HoverOverlay_MouseUp"
                MouseMove="HoverOverlay_MouseMove"
                MouseLeave="HoverOverlay_MouseLeave"
                MouseWheel="HoverOverlay_MouseWheel">
            <Line x:Name="CrosshairV" Stroke="Gray" StrokeThickness="1"
                  StrokeDashArray="4 2" Visibility="Hidden"/>
            <Line x:Name="CrosshairH" Stroke="Gray" StrokeThickness="1"
                  StrokeDashArray="4 2" Visibility="Hidden"/>

            <Border x:Name="HoverTooltip"
                    Background="#DDFFFFFF" BorderBrush="DimGray"
                    BorderThickness="1" Padding="6" CornerRadius="2"
                    Visibility="Hidden" Panel.ZIndex="10">
                <TextBlock x:Name="HoverText" FontFamily="Consolas" FontSize="12"/>
            </Border>
        </Canvas>

        <!-- ── No-data overlay (LightYellow — matches plot BG) ──────────── -->
        <Border x:Name="NoDataOverlay"
                Grid.Column="1" Grid.Row="0"
                Background="LightYellow"
                Visibility="Visible" IsHitTestVisible="False" Panel.ZIndex="15">
            <TextBlock Text="Place an XY Transfer Probe on the breadboard, then start the simulation."
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="Gray" FontSize="13"
                       TextWrapping="Wrap" TextAlignment="Center" MaxWidth="280"/>
        </Border>

        <!-- ── V-labels column (matches GraphView VLabels) ───────────────── -->
        <Grid x:Name="VLabels" Grid.Column="0" Grid.Row="0" Background="Transparent"/>
        
        <Grid x:Name="CurrentVLabels" Grid.Column="2" Grid.Row="0" Background="Transparent"/>
        

        <!-- ── H-labels row (matches GraphView HLabels) ──────────────────── -->
        <Border x:Name="ControlsHint"
                Grid.Column="1" Grid.Row="0"
                VerticalAlignment="Bottom" HorizontalAlignment="Center"
                Margin="0,0,0,4"
                Background="#77404040" CornerRadius="3" Padding="7,3"
                IsHitTestVisible="False" Panel.ZIndex="25">
            <TextBlock Foreground="White" FontSize="10"
                       Text="Scroll: zoom  |  Ctrl+Scroll: zoom X  |  Shift+Scroll: zoom Y  |  Middle drag: pan  |  A / dbl-click: fit"/>
        </Border>
        <Grid x:Name="HLabels" Grid.Column="1" Grid.Row="1" Background="Transparent"/>

        <!-- ── Toolbar (matches GraphView toolbar row) ───────────────────── -->
        <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Margin="0,0,10,0">
            <Button Content="Auto Scale  [A]" Margin="0,0,6,0"
                    Click="AutoScaleButton_Click"
                    ToolTip="Fit axes to the full data range (press A)."/>
            <Button Content="Export CSV" Margin="0,0,6,0"
                    Click="ExportCsvButton_Click"
                    ToolTip="Save the XY trace data to a CSV file."/>
            <ToggleButton x:Name="HoverToggle" Content="Hover Probe" Margin="0,0,6,0"
                          Checked="HoverToggle_Changed" Unchecked="HoverToggle_Changed"
                          ToolTip="Show a live crosshair with V_in / V_out readout."/>
            <ToggleButton x:Name="PinToggle" Content="📌 Pin"
                          Checked="PinToggle_Changed" Unchecked="PinToggle_Changed"
                          ToolTip="Keep this window always on top."/>
        </StackPanel>
    </Grid>
</Window>

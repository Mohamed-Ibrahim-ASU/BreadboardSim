<Window x:Class="SimGUI.GraphView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:app="clr-namespace:SimGUI"
        Title="Graph View" Height="330" Width="1100" Loaded="Window_Loaded" SizeChanged="Window_SizeChanged" Closing="Window_Closing">
    
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="Foreground" Value="#212529"/>
            <Setter Property="BorderBrush" Value="#CED4DA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E2E6EA"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#DAE0E5"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#DAE0E5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ToggleButton">
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="Foreground" Value="#212529"/>
            <Setter Property="BorderBrush" Value="#CED4DA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E2E6EA"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#0D6EFD"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#0A58CA"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="#2B2B2B"/>
            <Setter Property="Foreground" Value="#F1F1F1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="HasDropShadow" Value="True"/>
        </Style>
    </Window.Resources>

    <Grid x:Name="MainGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="36"/> 
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="65"/> 
            <ColumnDefinition Width="1*"/> 
            <ColumnDefinition Width="65"/> 
        </Grid.ColumnDefinitions>
        
        <Canvas x:Name="GraphArea" ClipToBounds="True" Grid.Column="1" Grid.Row="0" Margin="0" Background="LightYellow" />
        
        <Path x:Name="GraphDividers" Grid.Column="1" Grid.Row="0" Stroke="#666" StrokeThickness="2" />
        
        <app:TraceDisplay x:Name="TraceArea" Grid.Column="1" Grid.Row="0" />

        <Canvas x:Name="HoverOverlay" Grid.Column="1" Grid.Row="0" Background="Transparent" ClipToBounds="True" Panel.ZIndex="20"
                MouseMove="HoverOverlay_MouseMove" MouseEnter="HoverOverlay_MouseEnter" MouseLeave="HoverOverlay_MouseLeave"
                MouseLeftButtonDown="HoverOverlay_MouseLeftButtonDown" MouseWheel="HoverOverlay_MouseWheel">
            
            <Line x:Name="Cursor1Line" Stroke="DodgerBlue" StrokeThickness="2" Visibility="Hidden" />
            <Line x:Name="Cursor2Line" Stroke="OrangeRed" StrokeThickness="2" Visibility="Hidden" />
            <Border x:Name="CursorTooltip" Background="#EF222222" BorderBrush="Gray" BorderThickness="1" Padding="8" CornerRadius="4" Visibility="Hidden" Canvas.Left="10" Canvas.Top="10">
                <TextBlock x:Name="CursorText" FontFamily="Consolas" FontSize="12" Foreground="White" />
            </Border>

            <Line x:Name="CrosshairV" Stroke="Gray" StrokeThickness="1" StrokeDashArray="4 2" Visibility="Hidden" />
            <Border x:Name="HoverTooltip" Background="#DDFFFFFF" BorderBrush="DimGray" BorderThickness="1" Padding="6" CornerRadius="2" Visibility="Hidden">
                <TextBlock x:Name="HoverText" FontFamily="Consolas" FontSize="12" />
            </Border>
        </Canvas>
        <Border x:Name="FloatingHelpHUD" Grid.Column="1" Grid.Row="0" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="15,15,0,0" Background="#F2252526" BorderBrush="#3E3E42" BorderThickness="1" CornerRadius="4" Padding="15,12" Visibility="Collapsed" IsHitTestVisible="False" Panel.ZIndex="50">
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.25" BlurRadius="6" ShadowDepth="2"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="NAVIGATION" Foreground="#FFFFFF" FontWeight="Bold" FontSize="12" Margin="0,0,0,8"/>
                
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Scroll" Foreground="#99c1f0" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Pan Up/Down" Foreground="#B4B4B4"/>
                    
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Ctrl + Scroll" Foreground="#99c1f0" FontWeight="SemiBold" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                    <TextBlock Grid.Row="1" Grid.Column="2" Text="Zoom Time" Foreground="#B4B4B4" Margin="0,4,0,0"/>
                    
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Ctrl+Shift+Scroll" Foreground="#99c1f0" FontWeight="SemiBold" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                    <TextBlock Grid.Row="2" Grid.Column="2" Text="Zoom Voltage" Foreground="#B4B4B4" Margin="0,4,0,0"/>
                    
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Shift + Scroll" Foreground="#99c1f0" FontWeight="SemiBold" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                    <TextBlock Grid.Row="3" Grid.Column="2" Text="Zoom Current" Foreground="#B4B4B4" Margin="0,4,0,0"/>
                </Grid>

                <TextBlock Text="PER-PROBE MODE" Foreground="#FFFFFF" FontWeight="Bold" FontSize="12" Margin="0,0,0,5"/>
                <TextBlock Text="Hover over a specific trace's lane" Foreground="#CCCCCC" FontSize="11"/>
                <TextBlock Text="and scroll to zoom/pan its Y-Axis." Foreground="#CCCCCC" Margin="0,0,0,15" FontSize="11"/>

                <Rectangle Height="1" Fill="#555555" Margin="0,0,0,15"/>

                <TextBlock Text="TOOLS" Foreground="#FFFFFF" FontWeight="Bold" FontSize="12" Margin="0,0,0,10"/>
                <TextBlock Text="• Auto Trigger" Foreground="#E0E0E0" FontWeight="SemiBold"/>
                <TextBlock Text="Locks graph to rising edges to create a stabilized graph." Foreground="#AAAAAA" Margin="10,2,0,8" FontSize="11"/>
                    
                <TextBlock Text="• Cursors" Foreground="#E0E0E0" FontWeight="SemiBold"/>
                <TextBlock Text="Place two cursors anywhere to measure the ΔT/ΔV between both points." Foreground="#AAAAAA" Margin="10,2,0,8" FontSize="11"/>
                    
                <TextBlock Text="• Hover Probe" Foreground="#E0E0E0" FontWeight="SemiBold"/>
                <TextBlock Text="Live crosshair data." Foreground="#AAAAAA" Margin="10,2,0,0" FontSize="11"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,10,4">
            
            <StackPanel x:Name="AdvancedPanel" Orientation="Horizontal" Visibility="Collapsed">
                
                <ToggleButton x:Name="HelpToggle" Content=" Graph Guide " FontWeight="Bold" Margin="0,0,10,0" Padding="6,0" Foreground="DimGray" BorderBrush="Transparent" Background="Transparent" Checked="HelpToggle_Changed" Unchecked="HelpToggle_Changed" ToolTip="Show/Hide Graph Guide"/>
                <ToggleButton x:Name="PinToggle" Content="📌 Pin" Margin="0,0,6,0" Checked="PinToggle_Changed" Unchecked="PinToggle_Changed" ToolTip="Keep graph always on top of all windows."/>
                <Button Content="Export CSV" Margin="0,0,6,0" Click="ExportCsv_Click" ToolTip="Export data to a CSV file."/>
                <ToggleButton x:Name="TriggerModeToggle" Content="Auto Trigger" Margin="0,0,6,0" ToolTip="Locks graph to a rising edge to create a stabilized graph."/>
                <ToggleButton x:Name="CursorModeToggle" Content="Measure Cursors" Margin="0,0,6,0" Checked="CursorModeToggle_Changed" Unchecked="CursorModeToggle_Changed" ToolTip="Place two tracking lines."/>
                <ToggleButton x:Name="HoverModeToggle" Content="Hover Probe" Margin="0,0,10,0" Checked="HoverModeToggle_Changed" Unchecked="HoverModeToggle_Changed" ToolTip="Live crosshair."/>
                
                <ComboBox x:Name="ViewModeSelector" Width="135" Margin="0,0,10,0" SelectionChanged="ViewModeSelector_SelectionChanged" VerticalContentAlignment="Center">
                    <ComboBoxItem Content="Combined (V &amp; I)" IsSelected="True"/>
                    <ComboBoxItem Content="Domain Split (V / I)"/>
                    <ComboBoxItem Content="Per-Probe Split"/>
                </ComboBox>
            </StackPanel>
            
            <Rectangle Width="1" Fill="#CCC" Margin="0,2,10,2"/>
            <ToggleButton x:Name="AdvancedToggle" Content="Advanced Tools" Margin="0,0,10,0" Checked="AdvancedToggle_Changed" Unchecked="AdvancedToggle_Changed" FontWeight="SemiBold" ToolTip="Show/hide tools."/>
            <Button Content="Settings" Margin="0,0,60,0" Click="SettingsButton_Click" ToolTip="Configure Global Scales."/>
        </StackPanel>

        <Rectangle Grid.ColumnSpan="3" Height="1" Grid.Row="2" Stroke="Black" VerticalAlignment="Top"/>
        <Grid x:Name="HLabels" Grid.Column="1" Grid.Row="1" />
        <Grid x:Name="VLabels" Grid.RowSpan="3" Grid.Column="0" Background="#FAFAFA" />
        <Grid x:Name="CurrentVLabels" Grid.RowSpan="3" Grid.Column="2" Background="#FAFAFA" />
    </Grid>
</Window>